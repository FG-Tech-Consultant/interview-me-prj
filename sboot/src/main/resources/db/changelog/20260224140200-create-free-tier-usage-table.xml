<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260224140200-1" author="interview-me">
        <createTable tableName="free_tier_usage">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_free_tier_usage_tenant"
                             references="tenant(id)"/>
            </column>
            <column name="feature_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="usage_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="year_month" type="VARCHAR(7)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="free_tier_usage"
                             constraintName="uq_free_tier_usage_tenant_feature_month"
                             columnNames="tenant_id, feature_type, year_month"/>

        <createIndex tableName="free_tier_usage" indexName="idx_free_tier_usage_tenant_feature_month">
            <column name="tenant_id"/>
            <column name="feature_type"/>
            <column name="year_month"/>
        </createIndex>

        <rollback>
            <dropTable tableName="free_tier_usage"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
