<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260224160100-1" author="claude-code">
        <createTable tableName="story">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="experience_project_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="situation" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="task" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="result" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="metrics" type="JSONB"/>
            <column name="visibility" type="VARCHAR(20)" defaultValue="private">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMPTZ"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="story"
            baseColumnNames="tenant_id"
            constraintName="fk_story_tenant"
            referencedTableName="tenant"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            baseTableName="story"
            baseColumnNames="experience_project_id"
            constraintName="fk_story_experience_project"
            referencedTableName="experience_project"
            referencedColumnNames="id"/>

        <createIndex indexName="idx_story_tenant_id" tableName="story">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_story_experience_project_id" tableName="story">
            <column name="experience_project_id"/>
        </createIndex>

        <createIndex indexName="idx_story_deleted_at" tableName="story">
            <column name="deleted_at"/>
        </createIndex>

        <createIndex indexName="idx_story_visibility" tableName="story">
            <column name="visibility"/>
        </createIndex>

        <rollback>
            <dropTable tableName="story"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
