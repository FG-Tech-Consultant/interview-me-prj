<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260224180000-1" author="claude-code">
        <createTable tableName="linkedin_analysis">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="profile_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="overall_score" type="INT"/>
            <column name="error_message" type="TEXT"/>
            <column name="pdf_filename" type="VARCHAR(255)"/>
            <column name="analyzed_at" type="TIMESTAMPTZ"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="linkedin_analysis"
            baseColumnNames="tenant_id"
            constraintName="fk_linkedin_analysis_tenant"
            referencedTableName="tenant"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            baseTableName="linkedin_analysis"
            baseColumnNames="profile_id"
            constraintName="fk_linkedin_analysis_profile"
            referencedTableName="profile"
            referencedColumnNames="id"/>

        <createIndex tableName="linkedin_analysis" indexName="idx_linkedin_analysis_tenant_id">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="linkedin_analysis" indexName="idx_linkedin_analysis_profile_id">
            <column name="profile_id"/>
        </createIndex>

        <createIndex tableName="linkedin_analysis" indexName="idx_linkedin_analysis_status">
            <column name="status"/>
        </createIndex>

        <sql>
            ALTER TABLE linkedin_analysis ADD CONSTRAINT chk_linkedin_analysis_score
            CHECK (overall_score IS NULL OR (overall_score >= 0 AND overall_score &lt;= 100));

            ALTER TABLE linkedin_analysis ADD CONSTRAINT chk_linkedin_analysis_status
            CHECK (status IN ('PENDING', 'IN_PROGRESS', 'COMPLETED', 'FAILED'));
        </sql>

        <rollback>
            <dropTable tableName="linkedin_analysis"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
