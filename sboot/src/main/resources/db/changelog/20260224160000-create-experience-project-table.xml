<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260224160000-1" author="claude-code">
        <createTable tableName="experience_project">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="job_experience_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="context" type="TEXT"/>
            <column name="role" type="VARCHAR(255)"/>
            <column name="team_size" type="INT"/>
            <column name="tech_stack" type="JSONB"/>
            <column name="architecture_type" type="VARCHAR(100)"/>
            <column name="metrics" type="JSONB"/>
            <column name="outcomes" type="TEXT"/>
            <column name="visibility" type="VARCHAR(20)" defaultValue="private">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMPTZ"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="experience_project"
            baseColumnNames="tenant_id"
            constraintName="fk_experience_project_tenant"
            referencedTableName="tenant"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            baseTableName="experience_project"
            baseColumnNames="job_experience_id"
            constraintName="fk_experience_project_job_experience"
            referencedTableName="job_experience"
            referencedColumnNames="id"/>

        <createIndex indexName="idx_experience_project_tenant_id" tableName="experience_project">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_experience_project_job_experience_id" tableName="experience_project">
            <column name="job_experience_id"/>
        </createIndex>

        <createIndex indexName="idx_experience_project_deleted_at" tableName="experience_project">
            <column name="deleted_at"/>
        </createIndex>

        <rollback>
            <dropTable tableName="experience_project"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
