<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260224180100-1" author="claude-code">
        <createTable tableName="linkedin_section_score">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="analysis_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="section_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="section_score" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="quality_explanation" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="suggestions" type="JSONB"/>
            <column name="raw_content" type="TEXT"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="linkedin_section_score"
            baseColumnNames="tenant_id"
            constraintName="fk_linkedin_section_score_tenant"
            referencedTableName="tenant"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            baseTableName="linkedin_section_score"
            baseColumnNames="analysis_id"
            constraintName="fk_linkedin_section_score_analysis"
            referencedTableName="linkedin_analysis"
            referencedColumnNames="id"/>

        <createIndex tableName="linkedin_section_score" indexName="idx_linkedin_section_score_tenant_id">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="linkedin_section_score" indexName="idx_linkedin_section_score_analysis_id">
            <column name="analysis_id"/>
        </createIndex>

        <sql>
            ALTER TABLE linkedin_section_score ADD CONSTRAINT chk_linkedin_section_score
            CHECK (section_score >= 0 AND section_score &lt;= 100);

            ALTER TABLE linkedin_section_score ADD CONSTRAINT chk_linkedin_section_name
            CHECK (section_name IN ('HEADLINE', 'ABOUT', 'EXPERIENCE', 'EDUCATION', 'SKILLS', 'RECOMMENDATIONS', 'OTHER'));
        </sql>

        <rollback>
            <dropTable tableName="linkedin_section_score"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
