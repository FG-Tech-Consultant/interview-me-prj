<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260224150100-1" author="claude-code">
        <createTable tableName="export_history">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="profile_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="template_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="parameters" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="file_url" type="VARCHAR(500)"/>
            <column name="file_size_bytes" type="BIGINT"/>
            <column name="coins_spent" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="coin_transaction_id" type="BIGINT"/>
            <column name="error_message" type="TEXT"/>
            <column name="retry_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMPTZ"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="export_history" baseColumnNames="tenant_id"
            referencedTableName="tenant" referencedColumnNames="id"
            constraintName="fk_export_history_tenant"/>

        <addForeignKeyConstraint
            baseTableName="export_history" baseColumnNames="profile_id"
            referencedTableName="profile" referencedColumnNames="id"
            constraintName="fk_export_history_profile"/>

        <addForeignKeyConstraint
            baseTableName="export_history" baseColumnNames="template_id"
            referencedTableName="export_template" referencedColumnNames="id"
            constraintName="fk_export_history_template"/>

        <sql>
            ALTER TABLE export_history ADD CONSTRAINT chk_export_history_status
            CHECK (status IN ('PENDING', 'IN_PROGRESS', 'COMPLETED', 'FAILED'));
        </sql>

        <createIndex tableName="export_history" indexName="idx_export_history_tenant_id">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="export_history" indexName="idx_export_history_profile_id">
            <column name="profile_id"/>
        </createIndex>
        <createIndex tableName="export_history" indexName="idx_export_history_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="export_history" indexName="idx_export_history_created_at">
            <column name="created_at"/>
        </createIndex>

        <rollback>
            <dropTable tableName="export_history"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
