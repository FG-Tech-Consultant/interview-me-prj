<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260224140000-1" author="interview-me">
        <createTable tableName="coin_wallet">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false" unique="true"
                             foreignKeyName="fk_coin_wallet_tenant"
                             references="tenant(id)"/>
            </column>
            <column name="balance" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addCheckConstraint tableName="coin_wallet"
                            constraintName="chk_coin_wallet_balance_non_negative"
                            validate="true">balance >= 0</addCheckConstraint>

        <createIndex tableName="coin_wallet" indexName="idx_coin_wallet_tenant_id" unique="true">
            <column name="tenant_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="coin_wallet"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
