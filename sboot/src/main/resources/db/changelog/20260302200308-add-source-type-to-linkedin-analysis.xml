<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260302200308-1" author="claude-code">
        <addColumn tableName="linkedin_analysis">
            <column name="source_type" type="VARCHAR(20)" defaultValue="PDF">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <sql>
            ALTER TABLE linkedin_analysis ADD CONSTRAINT chk_linkedin_analysis_source_type
            CHECK (source_type IN ('PDF', 'ZIP', 'PROFILE'));
        </sql>

        <rollback>
            <sql>ALTER TABLE linkedin_analysis DROP CONSTRAINT IF EXISTS chk_linkedin_analysis_source_type;</sql>
            <dropColumn tableName="linkedin_analysis" columnName="source_type"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
