<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260429213000-1" author="nando-coding-specialist">
        <createTable tableName="job_posting">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="company_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="requirements" type="TEXT"/>
            <column name="benefits" type="TEXT"/>
            <column name="location" type="VARCHAR(255)"/>
            <column name="work_model" type="VARCHAR(50)"/>
            <column name="salary_range" type="VARCHAR(100)"/>
            <column name="experience_level" type="VARCHAR(50)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="required_skills" type="JSONB"/>
            <column name="nice_to_have_skills" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="job_posting"
            baseColumnNames="company_id"
            referencedTableName="company"
            referencedColumnNames="id"
            constraintName="fk_job_posting_company"/>

        <createIndex tableName="job_posting" indexName="idx_job_posting_tenant_id">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="job_posting" indexName="idx_job_posting_slug">
            <column name="slug"/>
        </createIndex>
        <createIndex tableName="job_posting" indexName="idx_job_posting_status">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropTable tableName="job_posting"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
